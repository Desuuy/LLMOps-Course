{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}],
  "__requires": [{"type": "grafana", "id": "grafana", "name": "Grafana", "version": "8.0.0"}, {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}],
  "annotations": {"list": []},
  "description": "SGLang inference server — throughput, latency, queue, KV cache",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100, "title": "📊 Overview Gauges", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1}, "id": 1,
      "title": "Request Throughput",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(sglang:http_requests_total[2m]))", "legendFormat": "req/s", "refId": "A"}],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "orange", "value": 50}, {"color": "red", "value": 200}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1}, "id": 2,
      "title": "Running Requests",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(sglang:num_running_reqs)", "legendFormat": "Running", "refId": "A"}],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "orange", "value": 10}, {"color": "red", "value": 50}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1}, "id": 3,
      "title": "Waiting Queue",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(sglang:num_queue_reqs)", "legendFormat": "Waiting", "refId": "A"}],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.8}, {"color": "red", "value": 0.95}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1}, "id": 4,
      "title": "GPU KV Cache Usage",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(sglang:token_usage) / sum(sglang:max_total_num_tokens)", "legendFormat": "KV cache %", "refId": "A"}],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "tok/s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1}, "id": 5,
      "title": "Token Generation Speed",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(sglang:num_generation_tokens_total[2m]))", "legendFormat": "tok/s", "refId": "A"}],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "orange", "value": 2}, {"color": "red", "value": 5}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1}, "id": 6,
      "title": "E2E Request Latency (avg)",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(sglang:e2e_request_latency_seconds_sum[5m]) / rate(sglang:e2e_request_latency_seconds_count[5m])", "legendFormat": "Avg E2E", "refId": "A"}],
      "type": "stat"
    },
    {
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101, "title": "📈 Throughput", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 6}, "id": 10, "title": "Running / Waiting Requests",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(sglang:num_running_reqs)", "legendFormat": "Running", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(sglang:num_queue_reqs)", "legendFormat": "Waiting", "refId": "B"}
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "tok/s", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 6}, "id": 11, "title": "Token Throughput (Prompt + Generation)",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(sglang:prompt_tokens_total[2m]))", "legendFormat": "Prompt tok/s", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(sglang:num_generation_tokens_total[2m]))", "legendFormat": "Generation tok/s", "refId": "B"}
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15},
      "id": 102, "title": "⏱️ Latency", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "s", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 16}, "id": 20, "title": "E2E Request Latency (P50/P95/P99)",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "histogram_quantile(0.50, sum(rate(sglang:e2e_request_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P50", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "histogram_quantile(0.95, sum(rate(sglang:e2e_request_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "histogram_quantile(0.99, sum(rate(sglang:e2e_request_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P99", "refId": "C"}
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "s", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 16}, "id": 21, "title": "Time to First Token (TTFT)",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "histogram_quantile(0.50, sum(rate(sglang:time_to_first_token_seconds_bucket[5m])) by (le))", "legendFormat": "TTFT P50", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "histogram_quantile(0.95, sum(rate(sglang:time_to_first_token_seconds_bucket[5m])) by (le))", "legendFormat": "TTFT P95", "refId": "B"}
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "id": 103, "title": "💾 KV Cache", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "percentunit", "min": 0, "max": 1, "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 26}, "id": 30, "title": "GPU KV Cache Usage %",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(sglang:token_usage) / sum(sglang:max_total_num_tokens)", "legendFormat": "GPU KV cache", "refId": "A"}
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 26}, "id": 31, "title": "Total Requests Completed",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(increase(sglang:num_requests_total[5m]))", "legendFormat": "Requests (5m)", "refId": "A"}
      ],
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "tags": ["sglang", "llm", "inference"],
  "templating": {
    "list": [
      {"current": {}, "hide": 0, "includeAll": false, "name": "DS_PROMETHEUS", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource"}
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "SGLang Inference Server",
  "uid": "sglang-inference-local",
  "version": 1
}
