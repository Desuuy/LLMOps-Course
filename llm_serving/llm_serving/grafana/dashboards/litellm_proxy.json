{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}],
  "__requires": [{"type": "grafana", "id": "grafana", "name": "Grafana", "version": "8.0.0"}, {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}],
  "annotations": {"list": []},
  "description": "LiteLLM Proxy — request rates, latency, cache, and model breakdown",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100, "title": "📊 Overview", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}, "unit": "short", "mappings": []}},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1, "title": "Total Requests",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "orientation": "auto"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(litellm_proxy_total_requests_metric_total)", "legendFormat": "Total", "refId": "A"}],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "orange", "value": 3}, {"color": "red", "value": 10}]}, "unit": "s"}},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 2, "title": "Avg LLM Latency",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "orientation": "auto"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(litellm_llm_api_latency_metric_sum) / sum(litellm_llm_api_latency_metric_count)", "legendFormat": "Avg latency", "refId": "A"}],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 3, "title": "In-Flight Requests",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "litellm_in_flight_requests", "legendFormat": "In-flight", "refId": "A"}],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 0.5}]}, "unit": "percentunit"}},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 4, "title": "Cache Hit Rate",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(litellm_cache_hits_metric_total) / (sum(litellm_cache_hits_metric_total) + sum(litellm_cache_misses_metric_total))", "legendFormat": "Hit rate", "refId": "A"}],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "id": 5, "title": "Success Count",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(litellm_proxy_total_requests_metric_total{status_code=\"200\"})", "legendFormat": "Success", "refId": "A"}],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "id": 6, "title": "Failures",
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(litellm_proxy_total_requests_metric_total{status_code!=\"200\"})", "legendFormat": "Failures", "refId": "A"}],
      "type": "stat"
    },
    {
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101, "title": "📈 Request Rate & Latency", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 6},
      "id": 10, "title": "Request Rate (req/s) by Model",
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(litellm_proxy_total_requests_metric_total[2m])) by (requested_model)", "legendFormat": "{{requested_model}}", "refId": "A"}
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "s", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 6},
      "id": 11, "title": "LLM API Latency (avg, P95, P99)",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "histogram_quantile(0.50, sum(rate(litellm_llm_api_latency_metric_bucket[5m])) by (le, model))", "legendFormat": "P50 {{model}}", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "histogram_quantile(0.95, sum(rate(litellm_llm_api_latency_metric_bucket[5m])) by (le, model))", "legendFormat": "P95 {{model}}", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "histogram_quantile(0.99, sum(rate(litellm_llm_api_latency_metric_bucket[5m])) by (le, model))", "legendFormat": "P99 {{model}}", "refId": "C"}
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15},
      "id": 102, "title": "🗑️ Tokens", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 16},
      "id": 20, "title": "Prompt Tokens / sec",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(litellm_prompt_tokens_metric_total[2m])) by (model)", "legendFormat": "{{model}}", "refId": "A"}
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 16},
      "id": 21, "title": "Completion Tokens / sec",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(litellm_completion_tokens_metric_total[2m])) by (model)", "legendFormat": "{{model}}", "refId": "A"}
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "id": 103, "title": "🔁 Cache", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
      "id": 30, "title": "Cache Hits vs Misses",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(litellm_cache_hits_metric_total[5m]))", "legendFormat": "Hits/s", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(litellm_cache_misses_metric_total[5m]))", "legendFormat": "Misses/s", "refId": "B"}
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "id": 31, "title": "Requests by Route",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(litellm_proxy_total_requests_metric_total[2m])) by (route)", "legendFormat": "{{route}}", "refId": "A"}
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 34},
      "id": 104, "title": "⚡ Backend Health", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 35},
      "id": 40, "title": "Backend Requests by API Base",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(litellm_deployment_total_requests_total[2m])) by (api_base, requested_model)", "legendFormat": "{{api_base}} — {{requested_model}}", "refId": "A"}
      ],
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "tags": ["litellm", "llm", "proxy"],
  "templating": {
    "list": [
      {"current": {}, "hide": 0, "includeAll": false, "name": "DS_PROMETHEUS", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource"}
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "LiteLLM Proxy",
  "uid": "litellm-proxy-local",
  "version": 1
}
